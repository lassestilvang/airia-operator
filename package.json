{
  "name": "airia-operator",
  "version": "1.0.0",
  "description": "Airia Autonomous Enterprise Operator",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "dev:watch": "tsx watch src/server/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "operator:up": "tsx scripts/up.ts",
    "operator:reset": "tsx scripts/reset.ts",
    "test": "echo \"No automated tests yet\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lassestilvang/airia-operator.git"
  },
  "keywords": [
    "airia",
    "agent-orchestration",
    "autonomous-operator"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
